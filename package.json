{
  "name": "remember",
  "version": "0.1.0",
  "description": "A Slack agent that preserves institutional memory for disaster response volunteer organizations.",
  "main": "dist/app.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "jest",
    "seed": "ts-node scripts/seedAirtable.ts",
    "seed:slack": "ts-node scripts/seedSlack.ts",
    "seed:link": "ts-node scripts/linkBotAuthor.ts",
    "boot-check": "bash scripts/boot-check.sh"
  },
  "license": "MIT",
  "private": true,
  "dependencies": {
    "@slack/bolt": "^4.7.3",
    "@slack/web-api": "^7.17.0",
    "airtable": "^0.12.2",
    "dotenv": "^17.4.2",
    "node-cron": "^4.5.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "@types/node-cron": "^3.0.11",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
